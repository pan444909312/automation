<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <settings>
        <setting name="cacheEnabled" value="true"/>
        <setting name="lazyLoadingEnabled" value="true"/>
        <setting name="multipleResultSetsEnabled" value="true"/>
        <setting name="useColumnLabel" value="true"/>
        <setting name="defaultExecutorType" value="SIMPLE"/>
        <!-- 配置驼峰命名规则，默认为false，即数据库字段必须与实体类属性一致 -->
        <setting name="mapUnderscoreToCamelCase" value="true"/>
    </settings>
    <!--每个 environments 对应一个数据库链接，未指定默认环境将会被加载，也就是default="test"的作用-->
    <environments default="test">
        <environment id="test">
            <transactionManager type="JDBC"/>
            <dataSource type="POOLED">
                <property name="driver" value="com.mysql.cj.jdbc.Driver"/>
                <property name="url"
                          value="jdbc:mysql://rm-3ns24734o9z8747d0.mysql.rds.aliyuncs.com:3306/fresh_test?useUnicode=true&amp;characterEncoding=utf-8&amp;tinyInt1isBit=false&amp;serverTimezone=GMT%2B8"
                />
                <property name="username" value="PF@_GSkFnRGA/BiqRecDkGlmHw=="/>
                <property name="password" value="20AR@PF@_oTN6Y5Dp8jj1W2A9t20mQfbeK9xEM/Vp"/>
                <property name="driver.encoding" value="utf-8"/>
            </dataSource>
        </environment>
    </environments>
    <!--mappers 是告诉 MyBatis 去哪寻找映射的 SQL 的语句。https://mybatis.org/mybatis-3/configuration.html#mappers -->
    <mappers>
        <mapper resource="mapper/UserMapper.xml"></mapper>
    </mappers>
</configuration>
