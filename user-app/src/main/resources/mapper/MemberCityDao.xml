<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.miller.userapp.mapper.member.MemberCityDao">
    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.hungrypanda.app.server.entity.member.MemberCityEntity" id="memberCityMap">
        <result property="memberCityId" column="member_city_id"/>
        <result property="cityId" column="city_id"/>
        <result property="packetNum" column="packet_num"/>
        <result property="memberPrice" column="member_price"/>
        <result property="savePrice" column="save_price"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="isDel" column="is_del"/>
        <result property="deratePrice" column="derate_price"/>
        <result property="title" column="title"/>
        <result property="isOpenDeliveryDiscount" column="is_open_delivery_discount"/>
        <result property="memberPrivilegeDesc" column="member_privilege_desc"/>
        <result property="moduleActivityId" column="module_activity_id"/>
        <result property="memberActivityName" column="member_activity_name"/>
        <result property="memberCardType" column="member_card_type"/>
        <result property="memberDiscountPrice" column="member_discount_price"/>
        <result property="bulletin" column="bulletin"/>
        <result property="popupsSts" column="popups_sts"/>
        <result property="popupsMainTitle" column="popups_main_title"/>
        <result property="popupsSubTitle" column="popups_sub_title"/>
        <result property="memberBenefit" column="member_benefit"/>
        <result property="memberVersion" column="member_version"/>
        <result property="autoRenew" column="auto_renew"/>
        <result property="firstMonthPrice" column="first_month_price"/>
        <result property="renewPrice" column="renew_price"/>
        <result property="version" column="version"/>

        <result property="addressConfigId" column="address_id"/>
        <result property="addressConfigId" column="address_config_id"/>
        <result property="cityName" column="city_name"/>
        <result property="countryName" column="country_name"/>
        <result property="checkoutSts" column="checkout_sts"/>
        <result property="deliveryUseNumLimit" column="delivery_use_num_limit"/>
        <result property="deliveryUseType" column="delivery_use_type" />
        <result property="deliveryUseVersion" column="delivery_use_version" />
        <result property="firstMonthPricePeriod" column="first_month_price_period" />
        <result property="firstPayPrice" column="first_pay_price" />
        <result property="firstRenewPayPrice" column="first_renew_pay_price" />
        <result property="tagId" column="tag_id" />
        <result property="isOpenShopPacket" column="is_open_shop_packet" />
        <result property="orderPriceThreshold" column="order_price_threshold" />
        <result property="renewInfoType" column="renew_info_type" />
        <result property="timeZone" column="time_zone" />
        <result property="memberStartTime" column="member_start_time" />
        <result property="memberEndTime" column="member_end_time" />
    </resultMap>
    <select id="getMemberCityByCityId" resultMap="memberCityMap">
        select mc.member_city_id, mc.city_id, mc.member_price, mc.member_discount_price, mc.member_privilege_desc,
               mc.member_card_type, mc.bulletin, mc.member_benefit, mc.member_version,mc.delivery_use_num,mc.version,
               mc.delivery_range_limit,mc.derate_price,mc.online_status,mc.is_open_delivery_discount,mc.auto_renew,mc.first_month_price,mc.renew_price,
               mc.checkout_sts,mcr.address_id,mc.delivery_use_num_limit,mc.delivery_use_type,mc.delivery_use_version,mc.first_month_price_period,
               mc.first_pay_price,mc.first_renew_pay_price,mc.tag_id,mc.is_open_shop_packet,mc.order_price_threshold,mc.renew_info_type,mc.time_zone
        from member_city mc
                 left join member_city_relation mcr on mcr.member_city_id = mc.member_city_id
        where mc.is_del = 0 and mcr.address_id = #{cityId} and mc.online_status = 1
    </select>
</mapper>