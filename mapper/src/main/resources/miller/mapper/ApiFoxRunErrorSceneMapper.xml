<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.miller.mapper.apifox.ApiFoxRunErrorSceneMapper">

    <update id="updateToDel" >
        update apifox_run_error_scene
        set is_del = 1
        where report_id = #{id}
          and is_del = 0;
    </update>

</mapper>
